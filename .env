# --- MCP Server config ---
# Logge-nivå: DEBUG | INFO (default) | WARNING | ERROR
LOG_LEVEL=INFO

# Port for streamable-HTTP transport. Kun brukt når serveren startes med 'http'.
PORT=8000


# --- SSB Agent API config ---
# --- Lokal LLM via Ollama ---
OLLAMA_API_BASE=http://localhost:11434

# Modell brukt av alle 4 agenter (planner, retriever, presenter, verifier).
# Bytt til "ollama_chat/qwen2.5:14b" hvis tool-calling er upålitelig.
AGENT_MODEL=ollama_chat/qwen2.5

# --- MCP-server-tilkobling ---
# URL til MCP-serveren med SSB-verktøyene. Default antar lokal kjøring.
MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# --- ADK API-server (brukt av client.py) ---
# Hvor adk api_server lytter. client.py kobler hit.
ADK_API_BASE_URL=http://127.0.0.1:8001

# Timeout (sekunder) for hvert /run-kall fra client.py. Hev hvis pipelinen er
# treg på lokal Ollama; senk hvis du vil "feile raskt".
CLIENT_TIMEOUT_SECONDS=600
